{
  "scopeName": "source.rust.embedded.svelte",
  "injectionSelector": "L:text.html.svelte",
  "patterns": [
    {
      "begin": "(<)(rust)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.svelte" },
        "2": { "name": "entity.name.tag.svelte" },
        "3": { "name": "punctuation.definition.tag.end.svelte" }
      },
      "end": "(</)(rust)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.svelte" },
        "2": { "name": "entity.name.tag.svelte" },
        "3": { "name": "punctuation.definition.tag.end.svelte" }
      },
      "contentName": "source.rust",
      "patterns": [
        { "include": "source.rust" }
      ]
    }
  ]
}
